{
  "manifest_version": 3,
  "name": "Accessibility Checker",
  "author": "Jairo Costa",
  "version": "1.8.5",
  "description": "Comprehensive accessibility audit with 16 checks including advanced WCAG 2.1 criteria screenshots by Jairo Costa (@soyJairoCosta)",
  "permissions": ["activeTab", "scripting", "storage", "notifications", "tabs", "sidePanel"],
  "background": {
    "scripts": ["src/browser-polyfill.js", "src/background.js"]
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "sidebar_action": {
    "default_panel": "popup.html",
    "default_title": "Accessibility Checker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "accessibility-checker@soyJairoCosta",
      "strict_min_version": "109.0"
    }
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+A"
      },
      "description": "Open Accessibility Checker"
    }
  }
}
